{
  "name": "SuperApp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:shell": "turbo dev --filter=shell",
    "dev:temp": "turbo dev --filter=temp",
    "dev:mfe-soe-grn": "turbo dev --filter=mfe-soe-grn",
    "build:shell": "turbo run build --filter=shell",
    "preview:shell": "turbo run preview --filter=shell",
    "build:temp": "turbo run build --filter=temp",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clone:temp": "turbo gen workspace --copy temp"
  },
  "devDependencies": {
    "@superapp/typescript-config": "workspace:*",
    "@turbo/gen": "^1.11.3",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
